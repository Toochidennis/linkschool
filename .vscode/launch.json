    "version": "0.2.0",
    "configurations": [
    
        {
            "name": "linkschool",
            "request": "launch",
            "type": "dart",
            "toolArgs": [
                "--dart-define-from-file=.vscode/dart_defines.json"
            ]
        },
        {
            "name": "linkschool (profile mode)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "profile",
            "toolArgs": [
                "--dart-define-from-file=.vscode/dart_defines.json"
            ]
        },
        {
            "name": "linkschool (release mode)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "release",
            "toolArgs": [
                "--dart-define-from-file=.vscode/dart_defines.json"
            ]
        }
    ]
}
